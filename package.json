{
  "name": "stem-classroom-3d",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Реалістична 3D-візуалізація STEM-кабінету інформатики (робототехніка LEGO Mindstorms NXT / SPIKE Prime)",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run test",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "serve dist -s -l 3000",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "serve": "^14.2.4",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  }
}
